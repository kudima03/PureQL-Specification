{
  "from": { "entity": "orders", "alias": "o" },
  "select": [
    { "entity": "o",        "field": "id",         "type": { "name": "uuid" },     "alias": "order_id" },
    { "entity": "o",        "field": "created_at", "type": { "name": "datetime" }, "alias": "order_date" },
    { "entity": "users",    "field": "name",        "type": { "name": "string" },   "alias": "customer_name" },
    { "entity": "users",    "field": "email",       "type": { "name": "string" },   "alias": "customer_email" },
    { "entity": "coupons",  "field": "code",        "type": { "name": "string" },   "alias": "coupon_code" }
  ],
  "joins": [
    {
      "type": "inner",
      "entity": "users",
      "on": {
        "operator": "eachEqual",
        "left":  { "entity": "o",     "field": "user_id", "type": { "name": "uuid" } },
        "right": { "entity": "users", "field": "id",      "type": { "name": "uuid" } }
      }
    },
    {
      "type": "left",
      "entity": "coupons",
      "on": {
        "operator": "eachEqual",
        "left":  { "entity": "o",       "field": "coupon_id", "type": { "name": "uuid" } },
        "right": { "entity": "coupons", "field": "id",        "type": { "name": "uuid" } }
      }
    }
  ]
}
